# ===== gemini-webapi-server 配置示例 =====
# 复制为 .env 后填写。多账号请用 accounts.json（见 accounts.json.example）。

# 单账号方式（accounts.json 不存在时生效）：从 gemini.google.com 浏览器 cookie 复制
SECURE_1PSID=
SECURE_1PSIDTS=

# 可选代理（如 http://127.0.0.1:7890）
PROXY=

# 访问口令：留空 = 不鉴权；设置后所有数据接口需 Authorization: Bearer <API_KEY>
API_KEY=

# 监听
HOST=0.0.0.0
PORT=18090
DEFAULT_MODEL=unspecified
